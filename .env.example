# ---- Supabase (frontend + backend) ----
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---- Google reCAPTCHA v3 ----
# Frontend (Vite exposes to the browser by VITE_ prefix)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
# Backend (server-only, never VITE_ prefixed)
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key

# ---- Upstash Redis (rate limiting, server-only) ----
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ---- Fast2SMS (server-only) ----
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ---- EmailJS (server-only; never expose VITE_ variants) ----
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
